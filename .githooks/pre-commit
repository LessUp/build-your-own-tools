#!/bin/sh

set -eu

changed_files=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$changed_files" ]; then
    exit 0
fi

run_step() {
    printf '\n==> %s\n' "$1"
    shift
    "$@"
}

contains_match() {
    printf '%s\n' "$changed_files" | grep -Eq "$1"
}

if contains_match '\.rs$'; then
    run_step "Rust lint" cargo fmt --all -- --check
    run_step "Rust clippy" cargo clippy --all-targets -- -D warnings
    run_step "Rust tests" cargo test --all --all-features
fi

if contains_match '(^gzip/go/|^htop/win/go/|\.go$)'; then
    run_step "Go lint" make lint-go
    run_step "Go tests" make test-go
fi

if contains_match '(^docs/|^en/|^public/|^\.vitepress/|^index\.md$|^README(\.zh-CN)?\.md$|^CHANGELOG\.md$|^CONTRIBUTING\.md$|^CODE_OF_CONDUCT\.md$|^SECURITY\.md$|^package(-lock)?\.json$)'; then
    run_step "Docs check" npm run docs:check
fi

if contains_match '\.md$' && command -v markdownlint-cli2 >/dev/null 2>&1; then
    markdown_files=$(printf '%s\n' "$changed_files" | grep -E '\.md$' || true)
    if [ -n "$markdown_files" ]; then
        run_step "Markdown lint" markdownlint-cli2 $markdown_files
    fi
fi

printf '\nAll pre-commit checks passed.\n'
